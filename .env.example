# Supabase is the intended shared backend for production hardening.
# The current display-name-only prototype runs without credentials and stores demo state in localStorage.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Needed for GitHub Pages project sites. Example: /ncaa26-prediction-market/
VITE_BASE_PATH=/ncaa26-prediction-market/
